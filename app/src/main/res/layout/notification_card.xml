<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@android:color/transparent"
    android:padding="16dp">

    <ImageView
        android:id="@+id/leftFlag"
        android:layout_width="60dp"
        android:layout_height="40dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/bg_flag_box"
        android:src="@drawable/flag_argentina"
        android:scaleType="centerCrop"
        android:clipToOutline="true"
        android:contentDescription="Left team flag" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/leftScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/score_white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_status_pill"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/statusLine1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/score_white"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/rightScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/score_white"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ImageView
        android:id="@+id/rightFlag"
        android:layout_width="60dp"
        android:layout_height="40dp"
        android:layout_marginStart="14dp"
        android:background="@drawable/bg_flag_box"
        android:src="@drawable/flag_france"
        android:scaleType="centerCrop"
        android:clipToOutline="true"
        android:contentDescription="Right team flag" />

</LinearLayout>